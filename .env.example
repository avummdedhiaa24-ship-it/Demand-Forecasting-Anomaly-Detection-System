# .env.example — copy to .env and fill in your values
# =====================================================================

# Application
APP_ENV=development          # development | staging | production
APP_SECRET_KEY=your-secret-key-change-in-production
DEBUG=true

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=demand_forecast
DB_USER=postgres
DB_PASSWORD=postgres

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Dashboard
DASHBOARD_PORT=8501

# Model Artifacts
MODEL_PATH=artifacts/models/best_model.pkl
ARTIFACTS_DIR=artifacts

# Logging
LOG_LEVEL=INFO
LOG_PATH=logs/system.log

# Monitoring
PROMETHEUS_PORT=9090
ENABLE_METRICS=true
